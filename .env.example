# Rune API Keys
# Copy this file to ~/.rune/.env and fill in your keys.
#
# The install script does this automatically, but you can also run:
#   cp .env.example ~/.rune/.env
#   source ~/.rune/.env

# OpenAI API key — required for OpenAI models (default)
# Get yours at: https://platform.openai.com/api-keys
export OPENAI_API_KEY=

# Anthropic API key — required for Anthropic/Claude models
# Get yours at: https://console.anthropic.com/
export ANTHROPIC_API_KEY=

# Tavily API key — optional, enables the web_search tool
# Get yours at: https://tavily.com/
export TAVILY_API_KEY=
